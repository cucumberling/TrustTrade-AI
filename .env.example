# ─────────────────────────────────────────────
# TrustTrade AI — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# Kraken API (read-only key for leaderboard verification)
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Kraken CLI path (usually auto-detected)
# KRAKEN_CLI_PATH=kraken

# ERC-8004 on-chain (Base Sepolia)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
AGENT_PRIVATE_KEY=

# LLM (optional — enables Claude-powered Manager Agent + headline NLP)
ANTHROPIC_API_KEY=
